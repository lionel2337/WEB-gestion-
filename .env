# Environment configuration for deployment
# -------------------------------------------------
# Update the values below with your local MySQL credentials
# and your SMTP settings before running the app.

DB_HOST=localhost
DB_NAME=gestion_personnel
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

BASE_URL=http://localhost/gestion_personnel

MAIL_FROM=no-reply@yourdomain.com
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
